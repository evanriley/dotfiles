#!/usr/bin/env bash
set -euo pipefail

doom_dir="${DOOMDIR:-$HOME/.config/doom}"
emacs_dir="${EMACSDIR:-$HOME/.emacs.d}"

if ! command -v emacs >/dev/null 2>&1; then
    echo "doom-bootstrap: emacs is not installed yet" >&2
    exit 127
fi

if [[ ! -d "$emacs_dir/.git" ]]; then
    git clone --depth=1 https://github.com/doomemacs/doomemacs "$emacs_dir"
fi

export DOOMDIR="$doom_dir"
"$emacs_dir/bin/doom" sync

if command -v systemctl >/dev/null 2>&1 && systemctl --user show-environment >/dev/null 2>&1; then
    systemctl --user daemon-reload
    systemctl --user enable --now emacs.service
fi
