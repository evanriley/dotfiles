[Unit]
Description=Discord
PartOf=graphical-session.target
After=graphical-session.target
Requisite=graphical-session.target

[Service]
ExecStart=%h/.config/scripts/keepalive-process exact Discord 10 /usr/bin/flatpak run com.discordapp.Discord --start-minimized
Restart=on-failure
RestartSec=10
KillMode=process

[Install]
WantedBy=niri.service
