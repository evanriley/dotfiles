[Unit]
Description=Lidarr music manager
Wants=network-online.target
After=network-online.target

[Container]
ContainerName=lidarr
Image=lscr.io/linuxserver/lidarr:latest
Pull=newer
Network=media-stack.network
UserNS=keep-id
PodmanArgs=--cpu-shares=256
PublishPort=127.0.0.1:8686:8686
Environment=PUID=1000
Environment=PGID=1000
Environment=TZ=America/New_York
Environment=UMASK=002
Volume=/var/home/evan/.local/share/media-stack/lidarr:/config:Z
Volume=/mnt/Media/Music:/music:z
Volume=/mnt/Media/Downloads:/downloads:z

[Service]
Restart=on-failure
RestartSec=30
Nice=10
CPUWeight=25
IOWeight=25
IOSchedulingClass=idle

[Install]
WantedBy=default.target
