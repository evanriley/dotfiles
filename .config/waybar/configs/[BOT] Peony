{
 
"include": "~/.config/waybar/modules",
"layer": "top",
//"mode": "dock",
"exclusive": true,
"passthrough": false,
"position": "bottom",
"spacing": 4,
"fixed-center": true,
"ipc": true,
//"margin-top": 5,
"margin-bottom": 5,
"width": 1444,
	
"modules-left": ["hyprland/workspaces#roman", "mpris", "tray#peony"],
  
"modules-center": ["clock#peony"], 
	
"modules-right": [
	"battery#peony",
	"custom/separator#blank",
	"backlight#peony",
	"custom/separator#blank",
	"pulseaudio",
	"custom/separator#blank",
	"temperature",
	"custom/separator#blank",	
	"network#peony",
	"custom/swaync"],


//M O D U L E S //

"clock#peony": {
	"interval": 60,
	"tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>",
	//"format": "{:%B | %a %d, %Y | %I:%M %p}",
	"format": "{:%B | %a %d, %Y | %H:%M}",
	"format-alt": "{:%a %b %d, %G}",
},

"wireplumber#peony": {
	"format": "{icon} {volume}",
	"format-muted": "ΎΣο Mute",
	"on-click": "~/.config/hypr/scripts/Volume.sh --toggle",
	"on-click-right": "pavucontrol -t 3",
	"on-scroll-up": "~/.config/hypr/scripts/Volume.sh --inc",
	"on-scroll-down": "~/.config/hypr/scripts/Volume.sh --dec",
	"format-icons": ["ΎΑο", "ΎΑπ", "≤░Χ╛", "ΎΑρ"], 
},

"backlight#peony": {
	"device": "intel_backlight",
	"format": "{percent}% {icon}",
	"format-icons": ["≤░δσ", "≤▒σΟ", "≤▒σΠ", "≤▒σΣ", "≤▒σΤ", "≤▒σΥ", "≤▒σΦ", "≤▒σΧ", "≤░δρ"],
},

"network#peony": {
	"format": "{ifname}",
	"format-wifi": "{icon}",
	"format-ethernet": "≤░Να",
	"format-disconnected": "≤░Νβ", 
	"tooltip-format": "{ipaddr} ΎΕ╣ {bandwidthUpBytes} ΎΕ║ {bandwidthDownBytes}",
	"format-linked": "≤░ΙΒ {ifname} (No IP)",
	"tooltip-format-wifi": "{essid} {icon} {signalStrength}%",
	"tooltip-format-ethernet": "{ifname} ≤░Να",
	"tooltip-format-disconnected": "≤░Νβ Disconnected",
	"max-length": 50,
	"format-icons": ["≤░νψ","≤░νθ","≤░νλ","≤░νξ","≤░νρ"]
},

"battery#peony": {
	"interval": 60,
	"align": 0,
	"rotate": 0,
	//"bat": "BAT1",
	//"adapter": "ACAD",
	"full-at": 100,
	"design-capacity": false,
	"states": {
    "good": 95,
    "warning": 30,
    "critical": 15
	},
	"format": "{icon}  {capacity}%",
	"format-charging": "ΎΔπ {capacity}%",
	"format-plugged": "≤▒αΨ {capacity}%",
	"format-full": "{icon} Full",
	"format-alt": "{icon} {time}",
	"format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"],
	"format-time": "{H}h {M}min",
	"tooltip": true,
	"tooltip-format": "{timeTo} {power}w",
	"on-click-middle": "~/.config/hypr/scripts/ChangeBlur.sh",
	"on-click-right": "~/.config/hypr/scripts/Wlogout.sh",
},

"tray#peony": {
	"icon-size": 17,
	"spacing": 8,
}
}	
